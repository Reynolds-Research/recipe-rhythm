{
  "name": "recipe-rhythm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Mobile-first meal planner I built for my wife. Voice-first logging, AI recipe parsing, household grocery lists. Directed by a UX researcher, coded by Claude.",
  "homepage": "https://recipe-rhythm.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matt-reynolds-research/recipe-rhythm.git"
  },
  "bugs": {
    "url": "https://github.com/matt-reynolds-research/recipe-rhythm/issues"
  },
  "license": "MIT",
  "author": "Matt Reynolds <matt.reynolds.research@gmail.com>",
  "keywords": [
    "meal-planning",
    "recipe-vault",
    "grocery-list",
    "react",
    "vite",
    "supabase",
    "anthropic",
    "pwa",
    "voice-input"
  ],
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,green \"npm:dev:client\" \"npm:dev:api\"",
    "dev:client": "vite",
    "dev:api": "node api-server.mjs",
    "start:server": "node api-server.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "backfill:structured-ingredients": "node scripts/backfill-structured-ingredients.mjs",
    "lint:ds": "grep -rn 'text-\\[1[0-3]px\\]' src/ --include='*.jsx' --include='*.js' | grep -v 'lint:ds-allow'; grep -rnE 'text-gray-(200|300|400)' src/ --include='*.jsx' --include='*.js' | grep -v 'lint:ds-allow'; grep -rnE '\\b(p|px|py|pt|pb|pl|pr)-[0-9]+\\.5\\b' src/ --include='*.jsx' --include='*.js' | grep -v 'lint:ds-allow'; echo 'lint:ds scan complete (non-zero output = violations found)'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.6",
    "react-modal-sheet": "^5.6.0",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
