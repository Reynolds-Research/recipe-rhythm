{
  "name": "recipe-rhythm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c blue,green \"npm:dev:client\" \"npm:dev:api\"",
    "dev:client": "vite",
    "dev:api": "node api-server.mjs",
    "start:server": "node api-server.mjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "backfill:structured-ingredients": "node scripts/backfill-structured-ingredients.mjs",
    "lint:ds": "grep -rn 'text-\\[1[0-3]px\\]' src/ --include='*.jsx' --include='*.js'; grep -rnE 'text-gray-(200|300|400)' src/ --include='*.jsx' --include='*.js'; grep -rnE '\\b(p|px|py|pt|pb|pl|pr)-[0-9]+\\.5\\b' src/ --include='*.jsx' --include='*.js'; echo 'lint:ds scan complete (non-zero output = violations found)'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-modal-sheet": "^5.6.0",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "vitest": "^4.1.4"
  }
}
