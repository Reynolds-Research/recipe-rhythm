# Copy this file to .env and fill in your values.

# --- Client-side (exposed to the browser via Vite) ---
# The VITE_ prefix tells Vite to inline these into the public client bundle.
# Only safe to expose when Supabase RLS is correctly configured on every
# table and storage bucket (see AUDIT.md C3).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Server-side (api-server.mjs only) ---
# No VITE_ prefix — that's deliberate. Variables without VITE_ are never
# exposed to the browser bundle, which is exactly what we want for
# secrets. api-server.mjs reads these at runtime via dotenv.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Port the proxy listens on; Vite's dev server proxies /api to it.
API_PORT=3001

# --- Backfill scripts only (NEVER expose to the browser) ---
# Used by scripts/backfill-ingredients-classification.js (PRD-004 Phase A)
# to bypass RLS for the cross-user one-time classification pass.
# DO NOT prefix with VITE_; do NOT reference from any code under src/.
# The script falls back to VITE_SUPABASE_URL for the URL when SUPABASE_URL
# is not set, but the service-role key is server-only with no fallback.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
