# Copy this file to .env and fill in your values.

# --- Client-side (exposed to the browser via Vite) ---
# The VITE_ prefix tells Vite to inline these into the public client bundle.
# Only safe to expose when Supabase RLS is correctly configured on every
# table and storage bucket (see AUDIT.md C3).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Server-side (api-server.mjs only) ---
# No VITE_ prefix — that's deliberate. Variables without VITE_ are never
# exposed to the browser bundle, which is exactly what we want for
# secrets. api-server.mjs reads these at runtime via dotenv.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Port the proxy listens on; Vite's dev server proxies /api to it.
API_PORT=3001

# --- Server-side Supabase access (NEVER expose to the browser) ---
# Used by:
#   - api-server.mjs + Vercel api/* serverless mirrors (ADR-004): read/write
#     the cross-user AI response cache tables. If unset, AI endpoints still
#     work — they just skip cache reads/writes and pay full Anthropic cost
#     every time.
#   - scripts/backfill-*.js (PRD-004 Phase A, PRD-006): bypass RLS for one-
#     time cross-user maintenance.
#
# DO NOT prefix with VITE_; do NOT reference from any code under src/.
# The service-role key is server-only with no fallback. Set both vars in
# your local .env AND in Vercel's project env settings (Production +
# Preview).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Server-side Supabase anon key (NEVER expose to the browser) ---
# Used by api-server.mjs + Vercel api/* to verify user JWTs on every
# /api/* request (PRD-001 P1.6). Same value as VITE_SUPABASE_ANON_KEY
# but without the VITE_ prefix — the server does NOT go through Vite.
# Must be set in Vercel env settings (Preview + Production) for auth to work.
SUPABASE_ANON_KEY=your-supabase-anon-key
