#!/bin/sh
# Pre-commit hook: scan staged changes for secrets via gitleaks.
# Aborts the commit if any potential secrets are detected.
#
# Bypass (only when you're certain): git commit --no-verify
#
# Setup: bash scripts/install-git-hooks.sh (one-time, after brew install gitleaks)

# Check that gitleaks is installed
if ! command -v gitleaks >/dev/null 2>&1; then
  echo ""
  echo "ERROR: gitleaks is not installed."
  echo "  Install with:  brew install gitleaks"
  echo "  Then re-run:   bash scripts/install-git-hooks.sh"
  echo ""
  echo "If you intentionally don't want this protection on this machine,"
  echo "remove .git/hooks/pre-commit (locally; the source stays in scripts/)."
  exit 1
fi

# Scan staged changes. --redact replaces actual secret values with [REDACTED]
# in the output so they don't appear in your terminal scrollback.
echo "Running gitleaks on staged changes..."
gitleaks protect --staged --redact -v
exit_code=$?

if [ $exit_code -ne 0 ]; then
  echo ""
  echo "================================================================"
  echo "  Commit BLOCKED: gitleaks flagged potential secrets above."
  echo "  Review the findings, remove the secret(s), then commit again."
  echo "  To bypass (rare — only if you're certain): git commit --no-verify"
  echo "================================================================"
  exit 1
fi

exit 0
